<Window x:Class="форма_сотрудника.ViewModels.RequestReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_сотрудника.ViewModels"
        mc:Ignorable="d"
        Height="1000" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Формальная проверка заявки" 
                   FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Результат проверки черного списка -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" CornerRadius="3" Padding="5" Margin="0,5" 
                Background="#FFF3CD" BorderBrush="#FFE69C" BorderThickness="1">
            <TextBlock Text="{Binding BlackListStatus}" FontWeight="Bold" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <Separator Grid.Row="3" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Информация о заявке -->
        <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="📋 Заявка" FontSize="13" FontWeight="Bold" Margin="0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="№:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Request.Id}" Margin="5" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Тип:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Request.RequestType}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="7" Grid.Column="1" Margin="5" VerticalAlignment="Center" FontSize="12">
            <TextBlock.Text>
                <Binding Path="Request.Status"/>
            </TextBlock.Text>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Request.Status}" Value="одобрена">
                            <Setter Property="Foreground" Value="Green"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Request.Status}" Value="не одобрена">
                            <Setter Property="Foreground" Value="Red"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Request.Status}" Value="проверка">
                            <Setter Property="Foreground" Value="Orange"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Цель:" VerticalAlignment="Top" FontSize="12"/>
        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Request.Purpose}" Margin="5" TextWrapping="Wrap" FontSize="12"/>

        <Separator Grid.Row="9" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Информация о посетителе -->
        <TextBlock Grid.Row="10" Grid.ColumnSpan="2" Text="👤 Посетитель" FontSize="13" FontWeight="Bold" Margin="0,5"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center" FontSize="12"/>
        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding Request.Visitor.LastName}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.FirstName}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.MiddleName}" FontSize="12"/>
        </StackPanel>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Паспорт:" VerticalAlignment="Center" FontSize="12"/>
        <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding Request.Visitor.PassportSeries}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.PassportNumber}" FontSize="12"/>
        </StackPanel>

        <TextBlock Grid.Row="13" Grid.Column="0" Text="Email:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding Request.Visitor.Email}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="14" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Request.Visitor.Phone}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="15" Grid.Column="0" Text="Организация:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding Request.Visitor.Organization}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <Separator Grid.Row="16" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Назначение даты и времени -->
        <TextBlock Grid.Row="17" Grid.ColumnSpan="2" Text="📅 Назначить дату и время" FontSize="13" FontWeight="Bold" Margin="0,5"/>

        <TextBlock Grid.Row="18" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" FontSize="12"/>
        <DatePicker Grid.Row="18" Grid.Column="1" SelectedDate="{Binding VisitDate}" 
                    Width="140" Height="26" HorizontalAlignment="Left" Margin="5"
                    IsEnabled="{Binding IsEditable}"/>

        <TextBlock Grid.Row="19" Grid.Column="0" Text="Время:" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="19" Grid.Column="1" Text="{Binding VisitTime}" 
                 Width="70" Height="26" HorizontalAlignment="Left" Margin="5"
                 IsEnabled="{Binding IsEditable}"/>

        <Separator Grid.Row="20" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="21" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="✅ Одобрить" Command="{Binding ApproveCommand}" 
                    Width="90" Height="30" Margin="8" FontSize="12"
                    Background="#2ECC71" Foreground="White" Cursor="Hand"
                    IsEnabled="{Binding CanApprove}"/>
            <Button Content="❌ Отказать" Command="{Binding RejectCommand}" 
                    Width="90" Height="30" Margin="8" FontSize="12"
                    Background="#E74C3C" Foreground="White" Cursor="Hand"
                    IsEnabled="{Binding CanReject}"/>
            <Button Content="Закрыть" Command="{Binding CloseCommand}" 
                    Width="80" Height="30" Margin="8" FontSize="12"
                    Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="22" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="10" TextWrapping="Wrap"/>

        <ProgressBar Grid.Row="23" Grid.ColumnSpan="2" IsIndeterminate="{Binding IsLoading}" Height="2" Margin="5"/>
    </Grid>
</Window>
