<Window x:Class="форма_для_сотрудника_охраны.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_для_сотрудника_охраны.Views"
        mc:Ignorable="d"
             Title="Поиск заявок - ХранительПРО" 
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Поиск заявок" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- Панель поиска -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5" Height="30" FontSize="14"/>
                <Button Grid.Column="2" Content="🔍 Найти" Command="{Binding SearchCommand}" 
                        Width="100" Height="35" Margin="10,0,0,0" FontSize="13"
                        Background="#2ECC71" Foreground="White" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Подсказка -->
        <TextBlock Grid.Row="2" Text="Поиск по фамилии, имени или номеру паспорта" 
                   Foreground="Gray" FontSize="11" HorizontalAlignment="Center" Margin="0,5"/>

        <!-- Результаты поиска -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding SearchResults}" 
                  SelectedItem="{Binding SelectedRequest}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,5"
                  RowHeight="40"
                  FontSize="12">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding RequestType}" Width="80"/>
                <DataGridTextColumn Header="Дата посещения" Binding="{Binding StartDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding Department.Name}" Width="150"/>
                <DataGridTextColumn Header="Посетитель" Binding="{Binding Visitor.LastName}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Green"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="🚪 Управление доступом" Command="{Binding OpenAccessCommand}" 
            Width="160" Height="40" Margin="10" FontSize="13"
            Background="#2ECC71" Foreground="White" Cursor="Hand"
            IsEnabled="{Binding SelectedRequest, Converter={StaticResource IsNotNullConverter}}"/>
            <Button Content="⏱ Убытие" Command="{Binding DepartureCommand}" 
            Width="100" Height="40" Margin="10" FontSize="13"
            Background="#F39C12" Foreground="White" Cursor="Hand"
            IsEnabled="{Binding SelectedRequest, Converter={StaticResource IsNotNullConverter}}"/>
            <Button Content="🔙 Закрыть" Command="{Binding CloseCommand}" 
            Width="100" Height="40" Margin="10" FontSize="13"
            Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <ProgressBar Grid.Row="6" IsIndeterminate="{Binding IsLoading}" Height="3" Margin="5"/>
    </Grid>
</Window>
