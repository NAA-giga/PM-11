<Window x:Class="форма_для_сотрудника_охраны.Views.AccessControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_для_сотрудника_охраны.Views"
        mc:Ignorable="d"
        Title="Управление доступом - ХранительПРО" 
        Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Управление доступом" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Информация о заявке -->
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="📋 Информация о заявке" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Номер:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Request.Id}" Margin="5" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Тип:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Request.RequestType}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Дата посещения:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Request.StartDate, StringFormat='dd.MM.yyyy'}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <Separator Grid.Row="6" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Информация о посетителе -->
        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Text="👤 Посетитель" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center" FontSize="12"/>
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding Request.Visitor.LastName}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.FirstName}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.MiddleName}" FontSize="12"/>
        </StackPanel>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Паспорт:" VerticalAlignment="Center" FontSize="12"/>
        <StackPanel Grid.Row="9" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding Request.Visitor.PassportSeries}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.PassportNumber}" FontSize="12"/>
        </StackPanel>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Организация:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding Request.Visitor.Organization}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <Separator Grid.Row="11" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Временные отметки -->
        <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="⏱ Временные отметки" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Время входа:" VerticalAlignment="Top" FontSize="12" Margin="0,64,0,0"/>
        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding EntryTime}" Margin="5,64,5,0" VerticalAlignment="Top" FontSize="12" Foreground="Green"/>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Время выхода:" VerticalAlignment="Top" FontSize="12" Margin="0,98,0,0" RenderTransformOrigin="0.231,0.414"/>
        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding ExitTime}" Margin="5,98,5,0" VerticalAlignment="Top" FontSize="12" Foreground="Red"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Left" Margin="121,125,0,25" Grid.ColumnSpan="2">
            <Button Content="🚪 Открыть турникет" Command="{Binding GrantAccessCommand}" 
                    Width="140" Height="35" Margin="8" FontSize="12"
                    Background="#2ECC71" Foreground="White" Cursor="Hand"
                    IsEnabled="{Binding HasEntry, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="⏱ Зафиксировать убытие" Command="{Binding RecordExitCommand}" 
                    Width="160" Height="35" Margin="8" FontSize="12"
                    Background="#E74C3C" Foreground="White" Cursor="Hand"
                    IsEnabled="{Binding HasExit, Converter={StaticResource InverseBooleanConverter}}"/>
            <Button Content="Закрыть" Command="{Binding CloseCommand}" 
                    Width="80" Height="35" Margin="8" FontSize="12"
                    Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="17" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11" TextWrapping="Wrap"/>

        <!-- Индикатор загрузки -->
        <ProgressBar Grid.Row="12" Grid.ColumnSpan="2" IsIndeterminate="{Binding IsLoading}" Height="2" Margin="5,209,5,118"/>
    </Grid>
</Window>
