<Window x:Class="форма_для_сотрудника_охраны.Views.RequestsListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_для_сотрудника_охраны.Views"
        mc:Ignorable="d"
          Title="Одобренные заявки - ХранительПРО" 
        Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Одобренные заявки на посещение" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker Grid.Column="1" SelectedDate="{Binding FilterDate}" 
                            Width="120" Height="25" Margin="0,0,20,0"/>

                <TextBlock Grid.Column="2" Text="Тип:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding RequestTypes}" 
                          SelectedItem="{Binding FilterRequestType}"
                          Width="100" Height="25" Margin="0,0,20,0"/>

                <TextBlock Grid.Column="4" Text="Подразделение:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="5" ItemsSource="{Binding Departments}" 
                          SelectedItem="{Binding FilterDepartment}"
                          DisplayMemberPath="Name"
                          Width="180" Height="25"/>
            </Grid>
        </Border>

        <!-- Таблица заявок -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Requests}" 
                  SelectedItem="{Binding SelectedRequest}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,5"
                  RowHeight="40"
                  FontSize="12">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding RequestType}" Width="80"/>
                <DataGridTextColumn Header="Дата посещения" Binding="{Binding StartDate, StringFormat='dd.MM.yyyy'}" Width="120"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding Department.Name}" Width="150"/>
                <DataGridTextColumn Header="Посетитель" Binding="{Binding Visitor.LastName}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Green"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="🚪 Управление доступом" Command="{Binding OpenAccessCommand}" 
                    Width="160" Height="40" Margin="10" FontSize="13"
                    Background="#2ECC71" Foreground="White" Cursor="Hand"/>
            <Button Content="⏱ Убытие" Command="{Binding DepartureCommand}" 
        Width="100" Height="40" Margin="10" FontSize="13"
        Background="#F39C12" Foreground="White" Cursor="Hand"/>
            <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}" 
                    Width="100" Height="40" Margin="10" FontSize="13"
                    Background="#3498DB" Foreground="White" Cursor="Hand"/>
            <Button Content="🔙 Назад" Command="{Binding GoToMainCommand}" 
                    Width="100" Height="40" Margin="10" FontSize="13"
                    Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <ProgressBar Grid.Row="5" IsIndeterminate="{Binding IsLoading}" Height="3" Margin="5"/>
    </Grid>
</Window>
