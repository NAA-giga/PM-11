<Window x:Class="форма_для_сотрудника_охраны.Views.DepartureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_для_сотрудника_охраны.Views"
        mc:Ignorable="d"
        Title="Фиксация убытия - ХранительПРО" 
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Фиксация убытия посетителя" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Информация о заявке -->
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="📋 Информация о заявке" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Номер заявки:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Request.Id}" Margin="5" VerticalAlignment="Center" FontWeight="Bold" FontSize="12"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Тип заявки:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Request.RequestType}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="5" Grid.Column="1" Margin="5" VerticalAlignment="Center" FontSize="12">
            <TextBlock.Text>
                <Binding Path="Request.Status"/>
            </TextBlock.Text>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Green"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Separator Grid.Row="6" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Информация о посетителе -->
        <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Text="👤 Информация о посетителе" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Фамилия:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Request.Visitor.LastName}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Имя:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding Request.Visitor.FirstName}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="10" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding Request.Visitor.MiddleName}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="Паспорт:" VerticalAlignment="Center" FontSize="12"/>
        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal" Margin="5">
            <TextBlock Text="{Binding Request.Visitor.PassportSeries}" Margin="0,0,3,0" FontSize="12"/>
            <TextBlock Text="{Binding Request.Visitor.PassportNumber}" FontSize="12"/>
        </StackPanel>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Организация:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding Request.Visitor.Organization}" Margin="5" VerticalAlignment="Center" FontSize="12"/>

        <Separator Grid.Row="13" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Временные отметки -->
        <TextBlock Grid.Row="14" Grid.ColumnSpan="2" Text="⏱ Временные отметки" 
                   FontSize="14" FontWeight="Bold" Margin="0,10"/>

        <TextBlock Grid.Row="15" Grid.Column="0" Text="Время входа:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding EntryTime}" Margin="5" VerticalAlignment="Center" FontSize="12" Foreground="Green"/>

        <TextBlock Grid.Row="16" Grid.Column="0" Text="Время выхода:" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Row="16" Grid.Column="1" Margin="5" VerticalAlignment="Center" FontSize="12">
            <TextBlock.Text>
                <Binding Path="ExitTime"/>
            </TextBlock.Text>
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="Red"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Separator Grid.Row="17" Grid.ColumnSpan="2" Margin="0,10" Height="1" Background="Gray"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="18" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15">
            <Button Content="✅ Зафиксировать убытие" Command="{Binding RecordExitCommand}" 
                    Width="160" Height="38" Margin="10" FontSize="13"
                    Background="#E74C3C" Foreground="White" Cursor="Hand"
                    IsEnabled="{Binding CanRecordExit}"/>
            <Button Content="🔙 Закрыть" Command="{Binding CloseCommand}" 
                    Width="100" Height="38" Margin="10" FontSize="13"
                    Background="#95A5A6" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="19" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11" TextWrapping="Wrap"/>

        <!-- Индикатор загрузки -->
        <ProgressBar Grid.Row="20" Grid.ColumnSpan="2" IsIndeterminate="{Binding IsLoading}" Height="2" Margin="5"/>
    </Grid>
</Window>
