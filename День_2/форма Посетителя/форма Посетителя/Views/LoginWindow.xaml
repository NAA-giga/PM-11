<Window x:Class="форма_Посетителя.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_Посетителя.Views"
        mc:Ignorable="d"
        Title="Авторизация - ХранительПРО" 
        Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Вход в систему ХранительПРО" 
                   FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,10" Height="2" Background="Gray"/>

        <!-- Логин -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Логин:*" VerticalAlignment="Center" FontSize="14"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LoginText, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" FontSize="14" />

        <!-- Пароль -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Пароль:*" VerticalAlignment="Center" FontSize="14"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="30" 
                     FontSize="14" PasswordChanged="PasswordBox_PasswordChanged"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Войти" Command="{Binding LoginCommand}" 
                    Width="120" Height="40" Margin="10" FontSize="14"/>
            <Button Content="Регистрация" Command="{Binding GoToRegisterCommand}" 
                    Width="120" Height="40" Margin="10" FontSize="14"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="10" FontSize="12"/>

        <!-- Индикатор загрузки -->
        <ProgressBar Grid.Row="6" Grid.ColumnSpan="2" IsIndeterminate="{Binding IsLoading}" 
                     Height="3" Margin="10" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
