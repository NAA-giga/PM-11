<Window x:Class="форма_Посетителя.Views.RequestsListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_Посетителя.Views"
        mc:Ignorable="d"
        Title="Мои заявки - ХранительПРО" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Мои заявки на посещение" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Панель фильтров -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
            <ComboBox ItemsSource="{Binding StatusFilters}" 
                      SelectedItem="{Binding FilterStatus}" 
                      Width="120" Height="25" Margin="0,0,10,0" FontSize="12"/>
            <Button Content="🔄 Обновить" Command="{Binding RefreshCommand}" 
                    Width="80" Height="25" Margin="0,0,10,0" FontSize="12"/>
        </StackPanel>

        <!-- Таблица заявок -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Requests}" 
                  SelectedItem="{Binding SelectedRequest}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,5"
                  RowHeight="35"
                  FontSize="12">

            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Наименование}" Width="180"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding ТипЗаявки}" Width="80"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding ДатаСозданиеЗаявки, StringFormat='dd.MM.yyyy HH:mm'}" Width="140"/>
                <DataGridTextColumn Header="Дата начала" Binding="{Binding ДатаНачалоРеализацииЗаявки, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Дата окончания" Binding="{Binding ДатаОкончаниеРеализацииЗаявки, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Подразделение" Binding="{Binding Подразделение.Наименование}" Width="150"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Сотрудник.Фамилия}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус загрузки -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
            <Button Content="🔍 Просмотреть детали" Command="{Binding ViewDetailsCommand}" 
                    Width="150" Height="35" Margin="10" FontSize="13"
                    Background="#3498DB" Foreground="White" Cursor="Hand"/>
            <Button Content="📝 Новая заявка" Command="{Binding NewRequestCommand}" 
                    Width="140" Height="35" Margin="10" FontSize="13"
                    Background="#2ECC71" Foreground="White" Cursor="Hand"/>
            <Button Content="🔙 Назад" Command="{Binding GoToMainCommand}" 
                    Width="100" Height="35" Margin="10" FontSize="13"
                    Background="#E74C3C" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <!-- Индикатор загрузки -->
        <ProgressBar Grid.Row="5" IsIndeterminate="{Binding IsLoading}" Height="3" Margin="5"/>
    </Grid>
</Window>
