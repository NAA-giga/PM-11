<Window x:Class="форма_Посетителя.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_Посетителя"
        mc:Ignorable="d"
       Title="Главное окно - ХранительПРО" 
        Height="600" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="ХранительПРО" 
                   FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Foreground="#2C3E50" 
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="Система управления пропускным режимом" 
                   FontSize="16" 
                   HorizontalAlignment="Center" 
                   Foreground="#7F8C8D" 
                   Margin="0,0,0,30"/>

        <!-- Приветствие -->
        <TextBlock Grid.Row="2" Text="{Binding WelcomeMessage}" 
                   FontSize="20" 
                   HorizontalAlignment="Center" 
                   Foreground="#34495E" 
                   Margin="0,0,0,40"/>

        <!-- Кнопки меню -->
        <StackPanel Grid.Row="2" Orientation="Vertical" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" Margin="158,52,0,0">

            <Button Content="📝 Подать индивидуальную заявку" 
                    Command="{Binding NewRequestCommand}" 
                    Width="300" Height="50" 
                    Margin="10" 
                    FontSize="16"
                    Background="#3498DB"
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content="👥 Подать групповую заявку" 
                    Command="{Binding GroupRequestCommand}" 
                    Width="300" Height="50" 
                    Margin="10" 
                    FontSize="16"
                    Background="#2ECC71"
                    Foreground="White"/>

            <Button Content="📋 Мои заявки" 
                    Command="{Binding MyRequestsCommand}" 
                    Width="300" Height="50" 
                    Margin="10" 
                    FontSize="16"
                    Background="#F39C12"
                    Foreground="White"
                    Cursor="Hand"/>

            <Button Content="🚪 Выход" 
                    Command="{Binding LogoutCommand}" 
                    Width="300" Height="50" 
                    Margin="10" 
                    FontSize="16"
                    Background="#E74C3C"
                    Foreground="White"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
