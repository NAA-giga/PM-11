<Window x:Class="форма_Посетителя.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_Посетителя.Views"
        mc:Ignorable="d"
      Title="Регистрация - ХранительПРО" 
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen">


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Регистрация нового пользователя" 
                   FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Separator Grid.Row="1" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Email -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:*" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RegisterModel.Email, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="300" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Пароль:*" VerticalAlignment="Center" FontSize="12"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="28" Width="300" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Подтверждение пароля -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Подтверждение:*" VerticalAlignment="Center" FontSize="12"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="4" Grid.Column="1" Margin="5" Height="28" Width="300" HorizontalAlignment="Left" FontSize="12"/>

        <Separator Grid.Row="5" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding RegisterModel.LastName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="250" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Имя -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Имя:*" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding RegisterModel.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="250" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding RegisterModel.MiddleName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="250" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding RegisterModel.Phone, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="250" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Дата рождения -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Дата рождения:*" VerticalAlignment="Center" FontSize="12"/>
        <DatePicker Grid.Row="10" Grid.Column="1" SelectedDate="{Binding RegisterModel.BirthDate}" 
                    Margin="5" Height="28" Width="180" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Серия паспорта -->
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Серия паспорта:*" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding RegisterModel.PassportSeries, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="100" HorizontalAlignment="Left" FontSize="12" MaxLength="4"/>

        <!-- Номер паспорта -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Номер паспорта:*" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding RegisterModel.PassportNumber, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="150" HorizontalAlignment="Left" FontSize="12" MaxLength="6"/>

        <!-- Организация -->
        <TextBlock Grid.Row="13" Grid.Column="0" Text="Организация:" VerticalAlignment="Center" FontSize="12"/>
        <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding RegisterModel.Organization, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="28" Width="250" HorizontalAlignment="Left" FontSize="12"/>

        <!-- Примечание -->
        <TextBlock Grid.Row="14" Grid.Column="0" Text="Примечание:" VerticalAlignment="Top" FontSize="12"/>
        <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding RegisterModel.Note, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="50" TextWrapping="Wrap" AcceptsReturn="True" FontSize="12"/>

        <Separator Grid.Row="15" Grid.ColumnSpan="2" Margin="0,5" Height="1" Background="Gray"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="16" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,15">
            <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" 
                    Width="160" Height="38" Margin="10" FontSize="13"
                    Background="#2ECC71" Foreground="White" Cursor="Hand"/>
            <Button Content="Назад к авторизации" Command="{Binding GoToLoginCommand}" 
                    Width="160" Height="38" Margin="10" FontSize="13"
                    Background="#3498DB" Foreground="White" Cursor="Hand"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="17" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="5" FontSize="11"/>

        <!-- Индикатор загрузки -->
        <ProgressBar Grid.Row="18" Grid.ColumnSpan="2" IsIndeterminate="{Binding IsLoading}" 
                     Height="3" Margin="5" VerticalAlignment="Bottom"/>
    </Grid>
</Window>
