<Window x:Class="форма_Посетителя.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:форма_Посетителя.Views"
        mc:Ignorable="d"
      Title="Регистрация - ХранительПРО" 
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Регистрация нового пользователя" 
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- Способ регистрации -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Способ регистрации:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RegistrationMethods}" 
                  SelectedItem="{Binding SelectedMethod}" Margin="5" Height="30" IsReadOnly="True"/>

        <Separator Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10" Height="2" Background="Gray"/>

        <!-- Email -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Email:*" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RegisterModel.Email, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="300" HorizontalAlignment="Left"/>

        <!-- Пароль -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Пароль:*" VerticalAlignment="Center"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" Margin="5" Height="30" Width="300" HorizontalAlignment="Left"/>

        <!-- Подтверждение пароля -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Подтверждение:*" VerticalAlignment="Center"/>
        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="5" Grid.Column="1" Margin="5" Height="30" Width="300" HorizontalAlignment="Left"/>

        <!-- Фамилия -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Фамилия:*" VerticalAlignment="Center"/>
        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding RegisterModel.LastName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="250" HorizontalAlignment="Left"/>

        <!-- Имя -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Имя:*" VerticalAlignment="Center"/>
        <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding RegisterModel.FirstName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="250" HorizontalAlignment="Left"/>

        <!-- Отчество -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Отчество:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding RegisterModel.MiddleName, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="250" HorizontalAlignment="Left"/>

        <!-- Телефон -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Телефон:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding RegisterModel.Phone, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="250" HorizontalAlignment="Left"/>

        <!-- Дата рождения -->
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Дата рождения:*" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="10" Grid.Column="1" SelectedDate="{Binding RegisterModel.BirthDate}" 
                    Margin="5" Height="30" Width="200" HorizontalAlignment="Left"/>

        <!-- Серия паспорта -->
        <TextBlock Grid.Row="11" Grid.Column="0" Text="Серия паспорта:*" VerticalAlignment="Center"/>
        <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding RegisterModel.PassportSeries, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="100" HorizontalAlignment="Left" MaxLength="4"/>

        <!-- Номер паспорта -->
        <TextBlock Grid.Row="12" Grid.Column="0" Text="Номер паспорта:*" VerticalAlignment="Center"/>
        <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding RegisterModel.PassportNumber, UpdateSourceTrigger=PropertyChanged}" 
                 Margin="5" Height="30" Width="150" HorizontalAlignment="Left" MaxLength="6"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="13" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Зарегистрироваться" Command="{Binding RegisterCommand}" 
                    Width="180" Height="40" Margin="10" FontSize="14"/>
            <Button Content="Назад к авторизации" Command="{Binding GoToLoginCommand}" 
                    Width="180" Height="40" Margin="10" FontSize="14"/>
        </StackPanel>

        <!-- Статус -->
        <TextBlock Grid.Row="14" Grid.ColumnSpan="2" Text="{Binding StatusMessage}" 
                   Foreground="Gray" HorizontalAlignment="Center" Margin="10"/>
    </Grid>
</Window>
